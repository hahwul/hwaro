# Embedded serif webfont data for scaffolds (Charis SIL, OFL 1.1).
#
# Charis SIL is the SIL-maintained serif derived from Bitstream Charter,
# so it delivers the scaffolds' Charter heading signature on every
# platform — not just Apple devices, where the system "Charter" is the
# only one that resolves. The @font-face blocks list `local("Charter")`
# first, so machines that already have Charter use it (no download) and
# everyone else falls back to these subset files.
#
# Latin subset woff2 from @fontsource/charis-sil, redistributed verbatim
# (byte-for-byte) and stored as base64 because scaffold assets travel as
# String content; decoded back to the original bytes at emit time (a
# String carries the raw bytes; File.write emits them verbatim). License:
# SIL Open Font License 1.1 — every site that ships the fonts also gets
# fonts/OFL.txt (see Base#font_files).

require "base64"

module Hwaro
  module Services
    module Scaffolds
      module EmbeddedFonts
        REGULAR_WOFF2_B64 = \
           ""
        BOLD_WOFF2_B64 = \
           ""
        ITALIC_WOFF2_B64 = \
           ""

        # Decoded woff2 bytes, carried in a String for the static-file map.
        # Decoded once into constants (not per call) — `static_files` is hit
        # repeatedly across init and the spec suite, and re-decoding ~68KB of
        # base64 on every call is pure waste (and needless CPU churn under the
        # multi-threaded spec build).
        REGULAR_WOFF2 = String.new(Base64.decode(REGULAR_WOFF2_B64))
        BOLD_WOFF2    = String.new(Base64.decode(BOLD_WOFF2_B64))
        ITALIC_WOFF2  = String.new(Base64.decode(ITALIC_WOFF2_B64))

        def self.regular : String
          REGULAR_WOFF2
        end

        def self.bold : String
          BOLD_WOFF2
        end

        def self.italic : String
          ITALIC_WOFF2
        end

